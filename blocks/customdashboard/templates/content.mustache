{{!
    @template block_customdashboard/content
    v4: course image in continue learning, "This week" dropdown filter,
        corrected attendance, timezone-safe greeting.
}}
<style>
/* ── Continue Learning: two-column body (text + image) ── */
.custom-dashboard .continue-body {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 0.5rem;
}
.custom-dashboard .continue-text-area {
    flex: 1;
    min-width: 0;
}
.custom-dashboard .continue-image-area {
    flex-shrink: 0;
    width: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.custom-dashboard .course-thumb {
    width: 130px;
    height: 110px;
    object-fit: cover;
    border-radius: 14px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.10);
}
.custom-dashboard .course-thumb-placeholder {
    opacity: 0.85;
}

/* ── "This week" filter dropdown ── */
.custom-dashboard .insight-filter-wrap {
    position: relative;
    display: inline-block;
}
.custom-dashboard .chart-tabs,.custom-dashboard .chart-tab.active {height: 40px;
    align-items: center;display: flex; justify-content:center;}
.custom-dashboard .insight-period-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1.5px solid #d1d5db;
    border-radius: 999px;
    padding: 0.3rem 0.9rem;
    font-size: 0.82rem;
    color: #374151;
    background: #fff;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s;
      height: 30px !important;
  span{text-transform: capitalize !important;}
}
.custom-dashboard .insight-period-badge:hover {
    border-color: #9ca3af;
}
.custom-dashboard .filter-chevron {
    color: #6b7280;
    transition: transform 0.2s;
}
.custom-dashboard .insight-filter-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    list-style: none;
    margin: 0;
    padding: 6px;
    min-width: 140px;
    z-index: 999;
}
.custom-dashboard .insight-filter-dropdown li {
    padding: 0.5rem 0.9rem;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #374151;
    cursor: pointer;
    transition: background 0.12s;
}
.custom-dashboard .insight-filter-dropdown li:hover {
    background: #f3f4f6;
}
.custom-dashboard .insight-filter-dropdown li.selected {
    background: #eef2ff;
    color: #3457d5;
    font-weight: 600;
}
@media (min-width: 992px) {
    .chart-area .chart-image {
        position: relative;
        margin: auto;
        height: 20vh;
        width: 41vw !important;
    }
}
.dashboard-stats-card {
    background: #fff;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
}

.dashboard-stats-card h3 {
    font-size: 20px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 4px;
}

.stats-subtitle {
    color: #9ca3af;
    font-size: 13px;
    margin-bottom: 20px;
}

.chart-tabs {
    background: #f3f4f6;
    border-radius: 12px;
    padding: 4px;
    display: flex;
    margin-bottom: 25px;
}

.chart-tab {
    flex: 1;
    border: 0;
    background: transparent;
    border-radius: 10px;
    padding: 10px;
    color: #9ca3af;
    font-weight: 500;
}

.chart-tab.active {
    background: #1e3a78;
    color: #fff;
}
p.chart-table-expand{display:none !important;}
.insight-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

</style>

{{! ══════ SKELETON ══════ }}
