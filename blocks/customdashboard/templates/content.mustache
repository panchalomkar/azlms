            <div class="cd-sk-session-item mt16"><div class="cd-sk-square"></div><div class="cd-sk-session-lines"><div class="cd-sk-line w70"></div><div class="cd-sk-line w40 mt4"></div></div><div class="cd-sk-tag"></div></div>
            <div class="cd-sk-session-item mt12"><div class="cd-sk-square"></div><div class="cd-sk-session-lines"><div class="cd-sk-line w70"></div><div class="cd-sk-line w40 mt4"></div></div><div class="cd-sk-tag"></div></div>
            <div class="cd-sk-session-item mt12"><div class="cd-sk-square"></div><div class="cd-sk-session-lines"><div class="cd-sk-line w70"></div><div class="cd-sk-line w40 mt4"></div></div><div class="cd-sk-tag"></div></div>
        </div>
