        <div class="cd-sk-card cd-sk-insight"><div class="cd-sk-circle"></div><div class="cd-sk-line w40 mt12"></div><div class="cd-sk-line w60 mt6"></div></div>
        <div class="cd-sk-card cd-sk-insight"><div class="cd-sk-circle"></div><div class="cd-sk-line w40 mt12"></div><div class="cd-sk-line w60 mt6"></div></div>
        <div class="cd-sk-card cd-sk-insight"><div class="cd-sk-circle"></div><div class="cd-sk-line w40 mt12"></div><div class="cd-sk-line w60 mt6"></div></div>
