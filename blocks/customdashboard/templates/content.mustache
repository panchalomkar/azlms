                <div class="cd-sk-dot"></div><div class="cd-sk-dot"></div>
                <div class="cd-sk-dot"></div><div class="cd-sk-dot"></div>
                <div class="cd-sk-dot"></div>
            </div>
        </div>
        <div class="cd-sk-card cd-sk-continue">
            <div class="cd-sk-line w30"></div>
            <div class="cd-sk-line w80 mt8"></div>
            <div class="cd-sk-line w50 mt4"></div>
